generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid()) @db.Uuid
  email             String   @unique @db.VarChar(255)
  name              String   @db.VarChar(100)
  passwordHash      String?  @db.VarChar(255)
  avatar            String?  @db.VarChar(500)
  preferredCurrency String   @default("USD") @db.VarChar(3)
  preferences       Json     @default("{}")
  googleId          String?  @unique @db.VarChar(255)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  groupMembers    GroupMember[]
  createdGroups   Group[]         @relation("GroupCreator")
  expensesPaid    ExpensePayer[]
  expenseSplits   ExpenseSplit[]
  createdExpenses Expense[]       @relation("ExpenseCreator")
  sentSettlements Settlement[]    @relation("SettlementFrom")
  receivedSettlements Settlement[] @relation("SettlementTo")
  transactions    Transaction[]
  budgets         Budget[]
  categories      Category[]      @relation("UserCategories")

  @@index([email])
  @@map("users")
}

model Group {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  type      String   @default("other") @db.VarChar(20)
  currency  String   @default("USD") @db.VarChar(3)
  settings  Json     @default("{}")
  createdBy String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator     User          @relation("GroupCreator", fields: [createdBy], references: [id])
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]

  @@index([createdBy])
  @@map("groups")
}

model GroupMember {
  id       String   @id @default(uuid()) @db.Uuid
  groupId  String   @db.Uuid
  userId   String   @db.Uuid
  role     String   @default("member") @db.VarChar(20)
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model Expense {
  id              String   @id @default(uuid()) @db.Uuid
  groupId         String   @db.Uuid
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("USD") @db.VarChar(3)
  amountInBase    Decimal  @default(0) @db.Decimal(12, 2)
  description     String   @db.VarChar(500)
  splitType       String   @db.VarChar(20)
  categoryId      String?  @db.Uuid
  tags            Json     @default("[]")
  attachments     Json     @default("[]")
  isRecurring     Boolean  @default(false)
  recurringConfig Json?
  createdBy       String   @db.Uuid
  date            DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  group    Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  category Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  creator  User          @relation("ExpenseCreator", fields: [createdBy], references: [id])
  payers   ExpensePayer[]
  splits   ExpenseSplit[]

  @@index([groupId])
  @@index([createdBy])
  @@index([categoryId])
  @@index([date])
  @@index([groupId, date])
  @@map("expenses")
}

model ExpensePayer {
  id        String  @id @default(uuid()) @db.Uuid
  expenseId String  @db.Uuid
  userId    String  @db.Uuid
  amount    Decimal @db.Decimal(12, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@index([expenseId])
  @@index([userId])
  @@map("expense_payers")
}

model ExpenseSplit {
  id         String   @id @default(uuid()) @db.Uuid
  expenseId  String   @db.Uuid
  userId     String   @db.Uuid
  amount     Decimal  @db.Decimal(12, 2)
  percentage Decimal? @db.Decimal(5, 2)
  shares     Int?

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@index([expenseId])
  @@index([userId])
  @@map("expense_splits")
}

model Settlement {
  id             String   @id @default(uuid()) @db.Uuid
  groupId        String   @db.Uuid
  fromUserId     String   @db.Uuid
  toUserId       String   @db.Uuid
  amount         Decimal  @db.Decimal(12, 2)
  currency       String   @default("USD") @db.VarChar(3)
  status         String   @default("pending") @db.VarChar(20)
  paymentMethod  String?  @db.VarChar(30)
  paymentDetails Json?
  note           String?  @db.VarChar(500)
  settledAt      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  fromUser User  @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser   User  @relation("SettlementTo", fields: [toUserId], references: [id])

  @@index([groupId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([groupId, status])
  @@map("settlements")
}

model Transaction {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  type        String   @db.VarChar(20)
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD") @db.VarChar(3)
  description String   @db.VarChar(500)
  categoryId  String?  @db.Uuid
  account     String   @db.VarChar(100)
  metadata    Json     @default("{}")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, date])
  @@index([userId, type])
  @@index([categoryId])
  @@map("transactions")
}

model Budget {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  categoryId     String?   @db.Uuid
  limitAmount    Decimal   @db.Decimal(12, 2)
  period         String    @db.VarChar(20)
  alertThreshold Decimal   @default(0.8) @db.Decimal(3, 2)
  startDate      DateTime  @default(now())
  endDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, categoryId])
  @@map("budgets")
}

model Category {
  id       String   @id @default(uuid()) @db.Uuid
  name     String   @db.VarChar(50)
  icon     String   @db.VarChar(50)
  color    String   @db.VarChar(7)
  parentId String?  @db.Uuid
  userId   String?  @db.Uuid
  isSystem Boolean  @default(false)
  createdAt DateTime @default(now())

  parent       Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryTree")
  user         User?         @relation("UserCategories", fields: [userId], references: [id])
  expenses     Expense[]
  transactions Transaction[]
  budgets      Budget[]

  @@index([userId])
  @@index([isSystem])
  @@map("categories")
}

model FeatureFlag {
  id             String   @id @default(uuid()) @db.Uuid
  key            String   @unique @db.VarChar(100)
  enabled        Boolean  @default(false)
  rolloutPercent Int      @default(100)
  targetUserIds  Json     @default("[]")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([key])
  @@map("feature_flags")
}
